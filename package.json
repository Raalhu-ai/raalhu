{
  "name": "mogger",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:frontend\"",
    "dev:server": "pnpm --filter mogger-server dev",
    "dev:frontend": "pnpm --filter mogger-frontend dev"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "wawoff2": "^2.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
