# Google OAuth credentials (used for Gemini Code Assist authentication)
# For local dev: set here or in .dev.vars
# For production: set via `wrangler secret put`
OAUTH_CLIENT_ID=your-google-oauth-client-id
OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Cloudflare KV namespace IDs
# Create with: wrangler kv:namespace create AUTH_SESSIONS
#              wrangler kv:namespace create SESSIONS
KV_AUTH_SESSIONS_ID=your-auth-sessions-namespace-id
KV_SESSIONS_ID=your-sessions-namespace-id

# CORS origin for frontend (defaults to http://localhost:5173)
# CORS_ORIGIN=https://your-domain.com
