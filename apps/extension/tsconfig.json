{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@raalhu/ui": ["../../packages/ui/src"],
      "@raalhu/ui/*": ["../../packages/ui/src/*"],
      "@raalhu/shared": ["../../packages/shared/src"],
      "@raalhu/shared/*": ["../../packages/shared/src/*"],
      "react-native": ["react-native-web"]
    }
  },
  "include": ["src"]
}
